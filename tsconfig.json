{
  "include": ["src", "test"],
  "compilerOptions": {
    "types": ["node"],
    "target": "ES2020",
    "module": "ES2020",
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "noEmit": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "baseUrl": "./"
  }
}